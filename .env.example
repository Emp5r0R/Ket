# Generate with: openssl rand -base64 48
KET_ADMIN_TOKEN=
KET_PUBLIC_URL=https://ket.example.com
KET_NODE_ID=in-hyd-1
KET_NODE_NAME=Hyderabad
KET_COUNTRY_CODE=IN
KET_COUNTRY_NAME=India
KET_CITY=Hyderabad
KET_LATITUDE=17.3850
KET_LONGITUDE=78.4867
KET_MAX_SESSIONS=1000
KET_SESSION_TTL_SECONDS=1800
KET_TRANSPORTS_JSON=[]

# Hysteria2 is enabled only when compose.hysteria.yaml is included.
KET_HYSTERIA_ENABLED=false
KET_HYSTERIA_PUBLIC_HOST=vpn.example.com
KET_HYSTERIA_PUBLIC_PORT=443
KET_HYSTERIA_SNI=vpn.example.com
KET_HYSTERIA_STATS_SECRET=
KET_HYSTERIA_MASQUERADE_URL=https://www.example.com/
KET_HYSTERIA_TLS_DIR=./secrets/tls
KET_HYSTERIA_TLS_CERT_PATH=/etc/hysteria/tls/fullchain.pem
KET_HYSTERIA_TLS_KEY_PATH=/etc/hysteria/tls/privkey.pem
KET_HYSTERIA_OBFS=none
# Required only for salamander or gecko; generate independently.
KET_HYSTERIA_OBFS_PASSWORD=
