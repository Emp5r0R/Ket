# Generate with: openssl rand -base64 48
KET_ADMIN_TOKEN=
KET_PUBLIC_URL=https://ket.example.com
KET_NODE_ID=in-hyd-1
KET_NODE_NAME=Hyderabad
KET_COUNTRY_CODE=IN
KET_COUNTRY_NAME=India
KET_CITY=Hyderabad
KET_LATITUDE=17.3850
KET_LONGITUDE=78.4867
KET_MAX_SESSIONS=1000
KET_SESSION_TTL_SECONDS=1800
KET_TRANSPORTS_JSON=[]

# Hysteria2 is enabled only when compose.hysteria.yaml is included.
KET_HYSTERIA_ENABLED=false
KET_HYSTERIA_PUBLIC_HOST=vpn.example.com
KET_HYSTERIA_PUBLIC_PORT=443
KET_HYSTERIA_SNI=vpn.example.com
KET_HYSTERIA_STATS_SECRET=
KET_HYSTERIA_MASQUERADE_URL=https://www.example.com/
KET_HYSTERIA_TLS_DIR=./secrets/tls
KET_HYSTERIA_TLS_CERT_PATH=/etc/hysteria/tls/fullchain.pem
KET_HYSTERIA_TLS_KEY_PATH=/etc/hysteria/tls/privkey.pem
KET_HYSTERIA_OBFS=none
# Required only for salamander or gecko; generate independently.
KET_HYSTERIA_OBFS_PASSWORD=

# REALITY uses compose.xray.yaml and HTTPS Stealth uses compose.xhttp.yaml.
# The overlays can be enabled independently or together.
KET_XRAY_ENABLED=false
KET_XRAY_PUBLIC_HOST=vpn.example.com
KET_XRAY_PUBLIC_PORT=443
KET_XRAY_SNI=www.cloudflare.com
KET_XRAY_SERVER_NAMES=www.cloudflare.com
KET_XRAY_REALITY_TARGET=www.cloudflare.com:443
# Generate the pair with: xray x25519
KET_XRAY_PRIVATE_KEY=
KET_XRAY_PUBLIC_KEY=
# Generate independently with: openssl rand -hex 8
KET_XRAY_SHORT_ID=
KET_XRAY_FINGERPRINT=chrome

# VLESS + XHTTP is carried through normal TLS/HTTP by Cloudflare Tunnel or a
# compatible CDN/reverse proxy. Generate an unguessable path, for example:
# /ket-$(openssl rand -hex 16)
KET_XHTTP_ENABLED=false
KET_XHTTP_PUBLIC_HOST=stealth.example.com
KET_XHTTP_PUBLIC_PORT=443
KET_XHTTP_SNI=stealth.example.com
KET_XHTTP_PATH=
KET_XHTTP_FINGERPRINT=chrome
# The origin is published to host loopback for cloudflared, never 0.0.0.0.
KET_XHTTP_ORIGIN_BIND_ADDRESS=127.0.0.1
KET_XHTTP_ORIGIN_PORT=8445

# Server-only key shared by enabled Xray inbounds. Generate independently with:
# openssl rand -base64 48
KET_XRAY_CREDENTIAL_KEY=
